{
  "name": "phenologue-pages",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "deploy:dev": "wrangler pages deploy .svelte-kit/cloudflare --project-name phenologue-dev --branch dev --commit-dirty=true",
    "deploy:prod": "wrangler pages deploy .svelte-kit/cloudflare --project-name phenologue --branch main --commit-dirty=true",
    "typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json"
  },
  "devDependencies": {
    "@sveltejs/adapter-cloudflare": "^4.7.0",
    "@sveltejs/kit": "^2.5.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "wrangler": "^3.95.0"
  }
}
